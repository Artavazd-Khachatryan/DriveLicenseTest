CREATE TABLE QuestionCategoryJunction (
    question_id INTEGER NOT NULL,
    category_id INTEGER NOT NULL,
    PRIMARY KEY (question_id, category_id),
    FOREIGN KEY (question_id) REFERENCES Question(id) ON DELETE CASCADE,
    FOREIGN KEY (category_id) REFERENCES QuestionCategory(id) ON DELETE CASCADE
);

insertQuestionCategory:
INSERT INTO QuestionCategoryJunction (question_id, category_id) VALUES (?, ?);

deleteQuestionCategories:
DELETE FROM QuestionCategoryJunction WHERE question_id = ?;

deleteAllQuestionCategories:
DELETE FROM QuestionCategoryJunction;

selectCategoriesForQuestion:
SELECT c.* FROM QuestionCategory c
JOIN QuestionCategoryJunction j ON c.id = j.category_id
WHERE j.question_id = ?;

selectQuestionsForCategory:
SELECT q.*, b.name AS book_name FROM Question q
JOIN QuestionCategoryJunction j ON q.id = j.question_id
JOIN Book b ON q.book_id = b.id
WHERE j.category_id = ?;